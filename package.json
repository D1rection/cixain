    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-obsidian-link": "^0.2.4",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
