{
  "name": "cixain",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-posts.js --dev && vite dev",
    "build:posts": "node scripts/build-posts.js",
    "build": "node scripts/build-posts.js && vite build && node scripts/static-renderer.js && node scripts/build-seo.js && node scripts/build-search-index.js",
